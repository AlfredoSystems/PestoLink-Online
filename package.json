{
  "name": "pestolink-online",
  "version": "1.0.0",
  "description": "Robot drivestation by AlfredoSystems",
  "author": "Jacob Williams",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "icons": "node scripts/generate-icons.js",
    "predev": "npm run icons",
    "dev": "vite",
    "prebuild": "npm run icons",
    "build": "vite build",
    "preview": "vite preview",
    "cap:sync": "cap sync",
    "cap:android": "cap open android",
    "cap:ios": "cap open ios",
    "cap:icons": "capacitor-assets generate --iconBackgroundColor \"#4dae50\" --iconBackgroundColorDark \"#4dae50\"",
    "electron:dev": "npm run build && electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^8.0.0",
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/screen-orientation": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "sharp": "^0.34.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.alfredosystems.pestolink",
    "productName": "PestoLink",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    }
  }
}
